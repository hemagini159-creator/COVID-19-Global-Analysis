      <column caption='RISK LEVEL' datatype='string' name='[Calculation_1419236592185344]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Total Deaths] &gt;= 100000 THEN &quot;High Danger&quot;&#13;&#10;ELSEIF [Total Deaths] &gt;= 50000 THEN &quot;Medium danger&quot;&#13;&#10;ELSE &quot;Low Danger&quot;&#13;&#10;END' />
